{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"outputs": [".svelte-kit/**", ".vercel/output/**"]
		},
		"check": {
			"cache": true
		},
		"lint": {
			"cache": true
		},
		"format": {
			"cache": true
		},
		"dev": {
			"persistent": true,
			"cache": false
		}
	}
}
