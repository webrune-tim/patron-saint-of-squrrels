{
	"name": "patron-saint-of-squirrels",
	"version": "0.0.1",
	"private": true,
	"description": "A birthday gift for Helen, the patron saint of squirrels.",
	"type": "module",
	"scripts": {
		"dev": "vp dev",
		"build": "vp build",
		"preview": "vp preview",
		"prepare": "vp config && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "vp fmt --check . && vp lint .",
		"format": "vp fmt ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-vercel": "next",
		"@sveltejs/enhanced-img": "^0.11.0",
		"@sveltejs/kit": "next",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/node": "^24.13.3",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"node-addon-api": "^8.9.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.2",
		"typescript": "^7.0.2",
		"typescript-eslint": "^8.64.0",
		"vite": "npm:@voidzero-dev/vite-plus-core@^0.2.4",
		"vite-plus": "catalog:"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.13.0",
			"onFail": "download"
		}
	},
	"packageManager": "pnpm@11.13.0",
	"dependencies": {
		"@hiseb/confetti": "^2.1.0",
		"turbo": "^2.10.5"
	}
}
