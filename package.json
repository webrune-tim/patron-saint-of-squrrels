{
  "name": "patron-saint-of-squirrels",
  "version": "0.0.1",
  "private": true,
  "description": "A birthday gift for Helen, the patron saint of squirrels.",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "prepare": "vp config && svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "vp fmt --check . && vp lint .",
    "format": "vp fmt ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-vercel": "next",
    "@sveltejs/enhanced-img": "^0.11.0",
    "@sveltejs/kit": "next",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^24.13.2",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.7.0",
    "node-addon-api": "^8.8.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.9.0"
}
